{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*\\.png|.*\\.svg|.*\\.jpg|.*\\.webp|.*\\.ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.js|.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/artisans", "destination": "/artisans.html" },
    { "source": "/clients", "destination": "/clients.html" },
    { "source": "/diaspora", "destination": "/diaspora.html" },
    { "source": "/fonctionnement", "destination": "/fonctionnement.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/tarifs", "destination": "/tarifs.html" },
    { "source": "/organisations", "destination": "/organisations.html" },
    { "source": "/politique", "destination": "/politique.html" }
  ]
}
